# Lien Calendly pour la section "Prendre RDV" sur la page Contact
VITE_CALENDLY_URL=https://calendly.com/votre-compte/30min

# Formulaire de contact – envoi des messages vers votre boîte mail
VITE_FORMSPREE_FORM_ID=mbdajdqe

# Google Tag Manager – ID du container (ex: GTM-XXXXXX). Laisser vide ou GTM-XXXXXX pour désactiver.
VITE_GTM_ID=GTM-XXXXXX

# Google Analytics 4 – ID de mesure (ex: G-PVBE1XMV9V). Utilisé pour les pages vues et le consentement.
VITE_GA4_MEASUREMENT_ID=G-PVBE1XMV9V

# URL publique du site (pour les canonical et données structurées). Ex: https://www.attitude-voyages.fr
# VITE_SITE_URL=https://www.attitude-voyages.fr
