{
  "name": "attitude-voyages",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.mjs && vite build && node scripts/postbuild.mjs",
    "build:prerender": "node scripts/generate-sitemap.mjs && vite build && node scripts/prerender.mjs && node scripts/postbuild.mjs",
    "preview": "vite preview",
    "cf:dev": "wrangler pages dev dist --d1=DB=attitude_voyages --compatibility-flag=nodejs_compat",
    "cf:deploy": "npm run build:prerender && wrangler pages deploy dist",
    "db:create": "wrangler d1 create attitude_voyages",
    "db:migrate:local": "wrangler d1 migrations apply attitude_voyages --local",
    "db:migrate:remote": "wrangler d1 migrations apply attitude_voyages --remote",
    "admin:seed": "node scripts/create-admin.mjs"
  },
  "dependencies": {
    "framer-motion": "^10.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "puppeteer": "^25.0.4",
    "tailwindcss": "^3.4.19",
    "vite": "^5.0.8",
    "wrangler": "^3.95.0"
  }
}
